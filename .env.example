# Example environment overrides for docker-compose.
# Copy to ".env" (docker compose loads it automatically) and edit as needed.

# ---------------------------------------------------------------------------- #
# Network exposure (security)
# ---------------------------------------------------------------------------- #
# Host interface to bind the published ports to. Default 127.0.0.1 (localhost
# only) - safe for a single-machine demo.
#
# The ros_bridge TCP port accepts UNAUTHENTICATED velocity commands, and the
# Gazebo Web UI is an UNAUTHENTICATED remote desktop (unless VNC_PASSWORD is
# set). Only expose them beyond localhost on a trusted/isolated network.

# ros_bridge TCP (:9090). Set to 0.0.0.0 to let an external SoftPLC connect.
# Protect it with a firewall / VPN / dedicated OT network when you do.
#BRIDGE_BIND=0.0.0.0

# Gazebo noVNC Web UI (:8080). Set to 0.0.0.0 for remote viewing.
#WEBUI_BIND=0.0.0.0

# Require a password for the Gazebo VNC/noVNC session. Strongly recommended if
# WEBUI_BIND is not localhost.
#VNC_PASSWORD=changeme

# ---------------------------------------------------------------------------- #
# ROS 2 / bridge tuning
# ---------------------------------------------------------------------------- #
# DDS domain. Change to isolate from other ROS 2 stacks on the same host/subnet.
#ROS_DOMAIN_ID=42

# ros_bridge DoS hardening limits (passed via the image environment).
#BRIDGE_MAX_CLIENTS=8
#BRIDGE_MAX_LINE_BYTES=65536
