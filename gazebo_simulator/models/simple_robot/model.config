<?xml version="1.0"?>
<!--
  Model manifest so the robot is discoverable as model://simple_robot.
  Gazebo Sim Harmonic resolves this via GZ_SIM_RESOURCE_PATH and loads the
  referenced file. libsdformat auto-detects the <robot> root and converts the
  URDF to SDF internally, so pointing <sdf> at simple_robot.urdf is supported.
-->
<model>
  <name>simple_robot</name>
  <version>1.0</version>
  <sdf version="1.8">simple_robot.urdf</sdf>
  <author>
    <name>gazebo-keyboard-control</name>
  </author>
  <description>
    Differential-drive demo robot (box chassis, two drive wheels, front
    caster) controlled via /gazebo/cmd_vel.
  </description>
</model>
