<?xml version="1.0"?>
<!--
  simple_robot - a differential-drive robot for the keyboard-control demo.

  Spec mapping and intentional adjustments (documented for review):

  1. Wheel lateral axis: the prose listed the wheels at (-0.15, 0, 0) and
     (+0.15, 0, 0) i.e. offset along X. A differential drive needs its two
     drive wheels offset left/right (Y in ROS REP-103), spinning about Y. So
     the wheels are placed at y = +0.15 (left) and y = -0.15 (right). The
     0.15 m magnitude and Y rotation axis from the spec are preserved; only
     the offset axis (X -> Y) is corrected so the robot actually steers.

  2. Z heights: the spec's flat coordinates (z = 0) would leave the wheels and
     caster floating relative to a base centered at z = 0.1. Heights are set so
     the wheels (r=0.05) and caster (r=0.02) contact the ground while the
     chassis keeps clearance. Spawn base_link at z ~= 0.13 (see empty.world).

  3. Joint type: the spec said "Revolute" for the wheels, but a drive wheel
     must spin without end stops -> "continuous" (revolute requires position
     limits). The 5 rad/s cap is kept as the joint velocity limit.

  Targets ROS Noetic URDF grammar and Gazebo (Ignition) Fortress. The
  differential-drive / IMU plugins below are the Ignition systems; for Gazebo
  Classic + Noetic, swap to libgazebo_ros_diff_drive.so (commented example
  included). ROS1 <-> Ignition topics are bridged with ros_gz_bridge.
-->
<robot name="simple_robot">

  <!-- ============================ Materials ============================ -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <!-- ============================ Base link ============================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.2"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5 0.3 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="0.10833" ixy="0.0" ixz="0.0"
               iyy="0.24167" iyz="0.0"
               izz="0.28333"/>
    </inertial>
  </link>

  <!-- ============================ Left wheel =========================== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000729" ixy="0.0" ixz="0.0"
               iyy="0.000729" iyz="0.0"
               izz="0.000625"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Left of body (y=+0.15), lowered so the wheel meets the ground. -->
    <origin xyz="0 0.15 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="5.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ============================ Right wheel ========================== -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.000729" ixy="0.0" ixz="0.0"
               iyy="0.000729" iyz="0.0"
               izz="0.000625"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Right of body (y=-0.15), lowered so the wheel meets the ground. -->
    <origin xyz="0 -0.15 -0.08" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10.0" velocity="5.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ============================ Caster wheel ========================= -->
  <link name="caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <!-- Front caster (x=+0.2), lowered so the sphere meets the ground. -->
    <origin xyz="0.2 0 -0.11" rpy="0 0 0"/>
  </joint>

  <!-- ===================== Gazebo material / friction ================== -->
  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <!-- Caster is nearly frictionless so it slides freely. -->
  <gazebo reference="caster">
    <material>Gazebo/DarkGray</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- ================ Differential drive (Ignition Fortress) =========== -->
  <!-- Subscribes to /gazebo/cmd_vel (output of the control_logic node) and
       publishes wheel odometry on /odom. -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.3</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/gazebo/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_velocity>2.0</max_linear_velocity>
      <min_linear_velocity>-2.0</min_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <min_angular_velocity>-2.0</min_angular_velocity>
    </plugin>
  </gazebo>

  <!-- ============================ IMU sensor =========================== -->
  <!-- Requires the Sensors system in the world file (see empty.world). -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <topic>/imu</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!--
    Gazebo Classic + ROS Noetic alternative (use instead of the Ignition
    DiffDrive plugin above if running classic Gazebo):

    <gazebo>
      <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros><namespace>/</namespace></ros>
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.3</wheel_separation>
        <wheel_diameter>0.1</wheel_diameter>
        <command_topic>/gazebo/cmd_vel</command_topic>
        <odometry_topic>/odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_link</robot_base_frame>
        <publish_odom>true</publish_odom>
        <max_wheel_torque>10.0</max_wheel_torque>
      </plugin>
    </gazebo>
  -->

</robot>
